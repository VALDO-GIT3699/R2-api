APP_ENV=production
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:5432/postgres
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
ALLOWED_ORIGINS=https://app.tudominio.com,https://admin.tudominio.com
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=8
APPLE_AUDIENCE=com.tudominio.recuER2
EMAIL_CHECK_DELIVERABILITY=true
